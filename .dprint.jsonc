{
    "indentWidth": 4,
    "lineWidth": 120,
    "newLineKind": "auto",
    "useTabs": false,
    "typescript": {
        "quoteStyle": "preferDouble",
        "semiColons": "always",
        "arrowFunction.useParentheses": "force"
    },
    "json": {
        "trailingCommas": "never"
    },
    "markdown": {
        "textWrap": "always",
        "lineWidth": 80
    },
    "yaml": {
        "indentWidth": 2,
        "quotes": "preferSingle"
    },
    "excludes": [
        "**/node_modules",
        "**/*-lock.json",
        "dist/**",
        "coverage/**",
        ".data/**",
        "pnpm-lock.yaml",
        ".changeset/*.md"
    ],
    "plugins": [
        "npm:@dprint/typescript",
        "npm:@dprint/json",
        "npm:@dprint/markdown",
        "npm:dprint-plugin-yaml"
    ]
}
